{
  "name": "@opensip-tools/lang-rust",
  "version": "2.6.2",
  "license": "MIT",
  "description": "Rust language adapter for opensip-tools",
  "keywords": ["opensip-tools", "static-analysis", "code-quality", "parser", "ast", "tree-sitter", "rust"],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/languages/lang-rust"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/core": "workspace:*",
    "@opensip-tools/tree-sitter": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "vitest": "^4.1.7"
  }
}
