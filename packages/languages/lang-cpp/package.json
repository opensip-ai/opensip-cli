{
  "name": "@opensip-tools/lang-cpp",
  "version": "2.13.0",
  "license": "MIT",
  "description": "C/C++ language adapter for opensip-tools (clang-tidy backed)",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "parser",
    "ast",
    "tree-sitter",
    "cpp",
    "c++"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/languages/lang-cpp"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "vitest": "^4.1.7"
  }
}
