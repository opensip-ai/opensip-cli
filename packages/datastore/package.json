{
  "name": "@opensip-tools/datastore",
  "version": "2.4.1",
  "license": "MIT",
  "description": "SQLite + Drizzle persistence layer for OpenSIP Tools — DataStore interface, backends, factory, schema migrations",
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/datastore"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@opensip-tools/core": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "drizzle-kit": "^0.31.10",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}
