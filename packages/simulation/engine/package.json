{
  "name": "@opensip-tools/simulation",
  "version": "2.7.1",
  "license": "MIT",
  "description": "Simulation scenarios for OpenSIP Tools",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "simulation",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/simulation/engine"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "opensipTools": {
    "kind": "tool",
    "id": "simulation",
    "apiVersion": 1,
    "commands": [
      { "name": "sim", "description": "Run simulation scenarios [experimental]" }
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/cli-ui": "workspace:*",
    "@opensip-tools/contracts": "workspace:*",
    "@opensip-tools/core": "workspace:*",
    "commander": "^14.0.3",
    "ink": "^7.0.4",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "ink-testing-library": "^4.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}
