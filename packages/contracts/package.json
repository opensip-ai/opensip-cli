  "dependencies": {
    "@opensip-cli/core": "workspace:*"
  },
  "peerDependencies": {
    "commander": "^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "commander": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "commander": "^15.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
