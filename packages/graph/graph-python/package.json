{
  "name": "@opensip-tools/graph-python",
  "version": "2.7.0",
  "license": "MIT",
  "description": "Python language adapter for the opensip-tools graph engine",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "call-graph",
    "dependency-graph",
    "python"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/graph/graph-python"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "opensipTools": {
    "kind": "graph-adapter"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/core": "workspace:*",
    "@opensip-tools/graph": "workspace:*",
    "@opensip-tools/graph-adapter-common": "workspace:*",
    "@opensip-tools/lang-python": "workspace:*",
    "@opensip-tools/tree-sitter": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "vitest": "^4.1.7"
  }
}
