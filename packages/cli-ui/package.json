  "license": "MIT",
  "description": "Shared Ink/React presentational primitives for OpenSIP Tools CLI tools — banner, spinner, run header, theme. Used by every tool that ships an Ink live view.",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "cli",
    "terminal",
    "ink",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/cli-ui"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
