{
  "name": "@opensip-cli/yagni",
  "version": "0.2.4",
  "license": "Apache-2.0",
  "description": "YAGNI reduction audit for OpenSIP CLI",
  "keywords": [
    "opensip-cli",
    "static-analysis",
    "code-quality"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-cli.git",
    "directory": "packages/yagni/engine"
  },
  "homepage": "https://github.com/opensip-ai/opensip-cli",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-cli/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "opensipTools": {
    "kind": "tool",
    "id": "yagni",
    "identity": {
      "name": "yagni",
      "aliases": [
        "yag"
      ]
    },
    "stableId": "3aba9195-2297-4f20-99d5-906945092dfc",
    "apiVersion": 1,
    "requires": [
      {
        "resource": "filesystem",
        "reason": "Reads source, package, and config files and writes temporary live-worker specs"
      },
      {
        "resource": "subprocess",
        "reason": "Live runs execute the yagni-run-worker through the shared off-thread runner"
      }
    ],
    "commands": [
      {
        "name": "yagni",
        "description": "Run YAGNI reduction audit detectors",
        "aliases": [
          "yag"
        ],
        "commonFlags": [
          "json",
          "cwd",
          "quiet",
          "verbose",
          "debug",
          "reportTo",
          "apiKey",
          "open"
        ],
        "options": [
          {
            "flag": "--gate-save",
            "description": "Architecture-gate: save current findings as baseline in the project SQLite store (mutually exclusive with --gate-compare)",
            "default": false
          },
          {
            "flag": "--gate-compare",
            "description": "Architecture-gate: compare current findings against the saved baseline; exit 1 on regression",
            "default": false
          },
          {
            "flag": "--sarif",
            "value": "<path>",
            "description": "Also write this run findings as SARIF 2.1.0. Composes with --gate-save; written even when the gate fails."
          },
          {
            "flag": "--min-confidence",
            "value": "<level>",
            "description": "Minimum confidence level: low, medium, or high",
            "choices": [
              "low",
              "medium",
              "high"
            ]
          },
          {
            "flag": "--detector",
            "value": "<slug>",
            "description": "Run only the named detector (repeatable)",
            "arrayDefault": []
          },
          {
            "flag": "--category",
            "value": "<name>",
            "description": "Filter findings by reduction category (repeatable)",
            "arrayDefault": []
          },
          {
            "flag": "--include-tests",
            "description": "Include test and fixture code in analysis",
            "default": false
          },
          {
            "flag": "--filter",
            "value": "<filter>",
            "description": "Agent filter (repeatable): errors-only, warnings-only, category:<name>, source:<slug>, file:<path>, high-impact, top:<n>",
            "arrayDefault": []
          },
          {
            "flag": "--top",
            "value": "<n>",
            "description": "Limit returned signals (sugar for --filter top:<n>)"
          },
          {
            "flag": "--raw",
            "description": "Emit unwrapped payload (no CommandOutcome wrapper)",
            "default": false
          }
        ],
        "args": [
          {
            "name": "paths",
            "description": "Limit analysis to one or more directory subtrees",
            "variadic": true,
            "optional": true
          }
        ],
        "scope": "project",
        "output": "raw-stream",
        "rawStreamReason": "runtime-render-dispatch",
        "producesVerdict": true
      },
      {
        "name": "yagni-run-worker",
        "description": "[internal] Run YAGNI headless and stream progress + result over IPC (forked by the live view)",
        "visibility": "internal",
        "commonFlags": [],
        "args": [
          {
            "name": "specPath",
            "description": "Path to a JSON YAGNI run spec file"
          }
        ],
        "scope": "project",
        "output": "raw-stream",
        "rawStreamReason": "worker-ipc"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-cli/cli-live": "workspace:*",
    "@opensip-cli/cli-ui": "workspace:*",
    "@opensip-cli/clone-detection": "workspace:*",
    "@opensip-cli/config": "workspace:*",
    "@opensip-cli/contracts": "workspace:*",
    "@opensip-cli/core": "workspace:*",
    "@opensip-cli/lang-typescript": "workspace:*",
    "commander": "^15.0.0",
    "react": "^19.2.7",
    "typescript": "~6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opensip-cli/graph-typescript": "workspace:*",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "vitest": "^4.1.9"
  }
}
