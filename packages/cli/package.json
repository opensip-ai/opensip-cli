{
  "name": "opensip-tools",
  "version": "3.0.0",
  "license": "MIT",
  "description": "OpenSIP Tools — codebase analysis from the command line (the CLI; `npm i -g opensip-tools`)",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "cli",
    "fitness-functions",
    "call-graph",
    "architecture",
    "linting",
    "code-review",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "bin": {
    "opensip-tools": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/checks-cpp": "workspace:*",
    "@opensip-tools/checks-go": "workspace:*",
    "@opensip-tools/checks-java": "workspace:*",
    "@opensip-tools/checks-python": "workspace:*",
    "@opensip-tools/checks-rust": "workspace:*",
    "@opensip-tools/checks-typescript": "workspace:*",
    "@opensip-tools/checks-universal": "workspace:*",
    "@opensip-tools/cli-ui": "workspace:*",
    "@opensip-tools/config": "workspace:*",
    "@opensip-tools/contracts": "workspace:*",
    "@opensip-tools/core": "workspace:*",
    "@opensip-tools/dashboard": "workspace:*",
    "@opensip-tools/datastore": "workspace:*",
    "@opensip-tools/fitness": "workspace:*",
    "@opensip-tools/graph": "workspace:*",
    "@opensip-tools/graph-go": "workspace:*",
    "@opensip-tools/graph-java": "workspace:*",
    "@opensip-tools/graph-python": "workspace:*",
    "@opensip-tools/graph-rust": "workspace:*",
    "@opensip-tools/graph-typescript": "workspace:*",
    "@opensip-tools/lang-cpp": "workspace:*",
    "@opensip-tools/lang-go": "workspace:*",
    "@opensip-tools/lang-java": "workspace:*",
    "@opensip-tools/lang-python": "workspace:*",
    "@opensip-tools/lang-rust": "workspace:*",
    "@opensip-tools/lang-typescript": "workspace:*",
    "@opensip-tools/output": "workspace:*",
    "@opensip-tools/session-store": "workspace:*",
    "@opensip-tools/simulation": "workspace:*",
    "@opensip-tools/targeting": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "commander": "^15.0.0",
    "ink": "^7.0.5",
    "open": "^11.0.0",
    "react": "^19.2.7",
    "update-notifier": "^7.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/update-notifier": "^6.0.8",
    "ink-testing-library": "^4.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
