{
  "name": "@opensip-tools/fitness",
  "version": "2.11.0",
  "license": "MIT",
  "description": "Fitness checks engine for OpenSIP Tools",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "fitness-functions",
    "linting",
    "architecture",
    "code-review"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/fitness/engine"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./internal": "./dist/internal.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "opensipTools": {
    "kind": "tool",
    "id": "fitness",
    "apiVersion": 1,
    "commands": [
      {
        "name": "fit",
        "description": "Run fitness checks"
      },
      {
        "name": "fit-list",
        "description": "List available fitness checks",
        "aliases": [
          "list-checks"
        ]
      },
      {
        "name": "fit-recipes",
        "description": "List available fitness recipes",
        "aliases": [
          "list-recipes"
        ]
      },
      {
        "name": "fit-baseline-export",
        "description": "Export the fit gate baseline (SARIF) from the datastore to a file"
      }
    ],
    "capabilities": [
      {
        "id": "fit-pack",
        "apiVersion": 1,
        "contributionKind": "module-export",
        "contributionSchema": {
          "requiredKeys": [
            "slug"
          ]
        }
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/cli-ui": "workspace:*",
    "@opensip-tools/config": "workspace:*",
    "@opensip-tools/contracts": "workspace:*",
    "@opensip-tools/core": "workspace:*",
    "@opensip-tools/datastore": "workspace:*",
    "@opensip-tools/session-store": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "glob": "^13.0.0",
    "ink": "^7.0.4",
    "minimatch": "^10.2.5",
    "react": "^19.2.6",
    "typescript": "~6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opensip-tools/lang-typescript": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "vitest": "^4.1.7"
  }
}
