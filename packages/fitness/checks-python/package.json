{
  "name": "@opensip-tools/checks-python",
  "version": "2.11.0",
  "license": "MIT",
  "description": "Python fitness checks for opensip-tools",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "fitness-checks",
    "linting",
    "python"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/fitness/checks-python"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "opensipTools": {
    "kind": "fit-pack"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/fitness": "workspace:*",
    "@opensip-tools/lang-python": "workspace:*",
    "@opensip-tools/tree-sitter": "workspace:*"
  },
  "devDependencies": {
    "@opensip-tools/core": "workspace:*",
    "@types/node": "^22.19.19",
    "vitest": "^4.1.7"
  }
}
