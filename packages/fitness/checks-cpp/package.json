{
  "name": "@opensip-cli/checks-cpp",
  "version": "0.2.2",
  "license": "Apache-2.0",
  "description": "C/C++ fitness checks (clang-tidy backed)",
  "keywords": [
    "opensip-cli",
    "static-analysis",
    "code-quality",
    "fitness-checks",
    "linting",
    "cpp",
    "c++"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-cli.git",
    "directory": "packages/fitness/checks-cpp"
  },
  "homepage": "https://github.com/opensip-ai/opensip-cli",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-cli/issues"
  },
  "type": "module",
  "opensipTools": {
    "kind": "fit-pack",
    "targetDomain": "fit-pack",
    "targetDomainApiVersion": 1
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-cli/core": "workspace:*",
    "@opensip-cli/fitness": "workspace:*"
  },
  "devDependencies": {
    "@opensip-cli/test-support": "workspace:*",
    "@types/node": "^24.13.2",
    "vitest": "^4.1.9"
  }
}
