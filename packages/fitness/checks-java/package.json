{
  "name": "@opensip-cli/checks-java",
  "version": "0.1.8",
  "license": "Apache-2.0",
  "description": "Java fitness checks for opensip-cli",
  "keywords": [
    "opensip-cli",
    "static-analysis",
    "code-quality",
    "fitness-checks",
    "linting",
    "java"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-cli.git",
    "directory": "packages/fitness/checks-java"
  },
  "homepage": "https://github.com/opensip-ai/opensip-cli",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-cli/issues"
  },
  "type": "module",
  "opensipTools": {
    "kind": "fit-pack"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-cli/fitness": "workspace:*"
  },
  "devDependencies": {
    "@opensip-cli/core": "workspace:*",
    "@opensip-cli/test-support": "workspace:*",
    "@types/node": "^24.13.2",
    "vitest": "^4.1.8"
  }
}
