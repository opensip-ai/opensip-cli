{
  "name": "@opensip-tools/dashboard",
  "version": "2.12.0",
  "license": "MIT",
  "description": "Self-contained HTML dashboard generator for OpenSIP Tools — renders the fit/sim/graph report from session data and graph catalogs",
  "keywords": [
    "opensip-tools",
    "static-analysis",
    "code-quality",
    "html-report",
    "visualization",
    "reporting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git",
    "directory": "packages/dashboard"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-vendor.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "vendor:cytoscape": "node scripts/vendor-cytoscape.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opensip-tools/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "cytoscape": "3.33.4",
    "cytoscape-dagre": "3.0.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}
