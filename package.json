{
  "name": "@opensip-tools/root",
  "version": "2.6.1",
  "private": true,
  "license": "MIT",
  "description": "OpenSIP Tools — open-source codebase analysis toolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test --continue -- --coverage",
    "typecheck": "turbo run typecheck",
    "lint": "eslint 'packages/**/src/**/*.{ts,tsx}' 'scripts/**/*.{mjs,js}' '*.{mjs,cjs}' && pnpm depcruise && pnpm depcruise:types && pnpm gate:verify",
    "lint:fix": "eslint --fix 'packages/**/src/**/*.{ts,tsx}' 'scripts/**/*.{mjs,js}' '*.{mjs,cjs}'",
    "depcruise": "depcruise packages",
    "gate:verify": "node scripts/verify-gate-live.mjs",
    "depcruise:types": "depcruise packages --config .dependency-cruiser.types.cjs",
    "clean": "turbo run clean",
    "cli": "node packages/cli/dist/index.js",
    "fit": "node packages/cli/dist/index.js fit",
    "fit:ci": "node packages/cli/dist/index.js fit --gate-save",
    "graph": "node packages/cli/dist/index.js graph",
    "graph:ci": "node packages/cli/dist/index.js graph --gate-save",
    "sim": "node packages/cli/dist/index.js sim",
    "dashboard": "node packages/cli/dist/index.js dashboard",
    "sessions": "node packages/cli/dist/index.js sessions",
    "docs:build": "node scripts/build-web-docs.mjs",
    "docs:check": "node scripts/build-web-docs.mjs --check",
    "docs:checks-index": "node scripts/extract-checks-metadata.mjs | node scripts/build-checks-index.mjs - > docs/public/70-reference/05-checks-index.md",
    "docs:checks-index:check": "node scripts/extract-checks-metadata.mjs | node scripts/build-checks-index.mjs - --check",
    "docs:readmes": "node scripts/build-package-readmes.mjs",
    "docs:readmes:check": "node scripts/build-package-readmes.mjs --check",
    "docs:keywords": "node scripts/build-package-keywords.mjs",
    "docs:keywords:check": "node scripts/build-package-keywords.mjs --check",
    "verify-release": "node scripts/verify-release.mjs",
    "smoke-pack": "node scripts/smoke-pack.mjs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opensip-tools/checks-typescript": "workspace:*",
    "@opensip-tools/checks-universal": "workspace:*",
    "@opensip-tools/fitness": "workspace:*",
    "@vitest/coverage-v8": "^4.1.7",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "turbo": "^2.9.16",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.1.0"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "engines": {
    "node": ">=22"
  }
}
