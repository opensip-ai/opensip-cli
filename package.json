{
  "name": "@opensip-cli/root",
  "version": "0.1.5",
  "private": true,
  "license": "Apache-2.0",
  "description": "OpenSIP CLI — codebase intelligence from your terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-cli.git"
  },
  "homepage": "https://github.com/opensip-ai/opensip-cli",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-cli/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test --continue -- --coverage",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write --config .config/prettier.config.mjs --ignore-path .prettierignore '**/*.{ts,tsx,mjs,cjs,js,json,yml,yaml}'",
    "format:check": "prettier --check --config .config/prettier.config.mjs --ignore-path .prettierignore '**/*.{ts,tsx,mjs,cjs,js,json,yml,yaml}'",
    "lint": "pnpm format:check && eslint --config .config/eslint.config.mjs 'packages/**/src/**/*.{ts,tsx}' 'scripts/**/*.{mjs,js}' '.config/*.{mjs,cjs}' && pnpm depcruise && pnpm depcruise:types && pnpm gate:verify && node scripts/verify-core-exports.mjs",
    "lint:fix": "pnpm format && eslint --fix --config .config/eslint.config.mjs 'packages/**/src/**/*.{ts,tsx}' 'scripts/**/*.{mjs,js}' '.config/*.{mjs,cjs}'",
    "depcruise": "depcruise packages --config .config/dependency-cruiser.cjs",
    "gate:verify": "node scripts/verify-gate-live.mjs",
    "depcruise:types": "depcruise packages --config .config/dependency-cruiser.types.cjs",
    "knip": "knip --config .config/knip.json",
    "clean": "turbo run clean",
    "cli": "node packages/cli/dist/index.js",
    "fit": "turbo run build && node packages/cli/dist/index.js fit",
    "fit:ci": "node packages/cli/dist/index.js fit --gate-save",
    "graph": "turbo run build && node packages/cli/dist/index.js graph",
    "graph:ci": "node packages/cli/dist/index.js graph --gate-save",
    "graph:catalog-diff": "pnpm build && node scripts/graph-catalog-diff.mjs",
    "bench:partition": "pnpm build && node scripts/bench-partition-strategies.mjs",
    "graph:equivalence:ci": "node packages/cli/dist/index.js graph-equivalence-check",
    "sim": "node packages/cli/dist/index.js sim",
    "report": "node packages/cli/dist/index.js report",
    "sessions": "node packages/cli/dist/index.js sessions",
    "docs:build": "node scripts/build-web-docs.mjs",
    "docs:check": "node scripts/build-web-docs.mjs --check",
    "docs:freshness": "node scripts/check-docs-freshness.mjs",
    "docs:checks-index": "node scripts/extract-checks-metadata.mjs | node scripts/build-checks-index.mjs - > docs/public/70-reference/05-checks-index.md",
    "docs:checks-index:check": "node scripts/extract-checks-metadata.mjs | node scripts/build-checks-index.mjs - --check",
    "docs:readmes": "node scripts/build-package-readmes.mjs",
    "docs:readmes:check": "node scripts/build-package-readmes.mjs --check",
    "docs:keywords": "node scripts/build-package-keywords.mjs",
    "docs:keywords:check": "node scripts/build-package-keywords.mjs --check",
    "licenses:sync": "node scripts/sync-package-licenses.mjs",
    "licenses:check": "node scripts/sync-package-licenses.mjs --check",
    "verify-release": "node scripts/verify-release.mjs",
    "supply-chain:verify": "node scripts/verify-supply-chain.mjs",
    "smoke-pack": "node scripts/smoke-pack.mjs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opensip-cli/checks-cpp": "workspace:*",
    "@opensip-cli/checks-go": "workspace:*",
    "@opensip-cli/checks-java": "workspace:*",
    "@opensip-cli/checks-python": "workspace:*",
    "@opensip-cli/checks-rust": "workspace:*",
    "@opensip-cli/checks-typescript": "workspace:*",
    "@opensip-cli/checks-universal": "workspace:*",
    "@opensip-cli/fitness": "workspace:*",
    "@opensip-cli/graph-go": "workspace:*",
    "@opensip-cli/graph-java": "workspace:*",
    "@opensip-cli/graph-python": "workspace:*",
    "@opensip-cli/graph-rust": "workspace:*",
    "@opensip-cli/graph-typescript": "workspace:*",
    "@vitest/coverage-v8": "^4.1.8",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "turbo": "^2.9.17",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "engines": {
    "node": ">=24"
  }
}
