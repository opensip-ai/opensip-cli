{
  "name": "@opensip-tools/root",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "description": "OpenSIP Tools — open-source codebase analysis toolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/opensip-ai/opensip-tools.git"
  },
  "homepage": "https://github.com/opensip-ai/opensip-tools",
  "bugs": {
    "url": "https://github.com/opensip-ai/opensip-tools/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint 'packages/**/src/**/*.{ts,tsx}' && pnpm depcruise",
    "lint:fix": "eslint --fix 'packages/**/src/**/*.{ts,tsx}'",
    "depcruise": "depcruise packages",
    "depcruise:graph": "depcruise --output-type dot packages | dot -T svg > docs/dependency-graph.svg",
    "clean": "turbo run clean",
    "cli": "node packages/cli/dist/index.js",
    "fit": "node packages/cli/dist/index.js fit",
    "dashboard": "node packages/cli/dist/index.js dashboard",
    "sessions": "node packages/cli/dist/index.js sessions",
    "docs:build": "node tools/build-web-docs.mjs",
    "docs:check": "node tools/build-web-docs.mjs --check",
    "verify-release": "node tools/verify-release.mjs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^2.1.9",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "knip": "^6.13.1",
    "turbo": "^2.5.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.59.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "tree-sitter-go", "tree-sitter-java"]
  }
}
