      "@opensip-tools/checks-java": ["packages/fitness/checks-java/src/index.ts"],
      "@opensip-tools/checks-cpp": ["packages/fitness/checks-cpp/src/index.ts"],
      "@opensip-tools/checks-rust": ["packages/fitness/checks-rust/src/index.ts"],
      "@opensip-tools/lang-typescript": ["packages/languages/lang-typescript/src/index.ts"],
