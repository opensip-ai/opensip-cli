{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignore": [".claude/**", "**/__fixtures__/**", "**/fixtures/**"],
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    ".": {
      "entry": ["opensip-tools/fit/checks/*.mjs", "opensip-tools/fit/recipes/*.mjs"],
      "ignoreDependencies": [
        "@opensip-tools/checks-typescript",
        "@opensip-tools/checks-universal",
        "@opensip-tools/checks-cpp",
        "@opensip-tools/checks-go",
        "@opensip-tools/checks-java",
        "@opensip-tools/checks-python",
        "@opensip-tools/checks-rust",
        "@opensip-tools/fitness",
        "vite"
      ]
    },
    "packages/cli": {
      "entry": ["src/__tests__/fixtures/**/*.{ts,js}"],
      "ignoreDependencies": [
        "@opensip-tools/fitness",
        "@opensip-tools/graph",
        "@opensip-tools/simulation",
        "@opensip-tools/checks-typescript",
        "@opensip-tools/checks-universal",
        "@opensip-tools/checks-cpp",
        "@opensip-tools/checks-go",
        "@opensip-tools/checks-java",
        "@opensip-tools/checks-python",
        "@opensip-tools/checks-rust",
        "@opensip-tools/graph-typescript",
        "@opensip-tools/graph-python",
        "@opensip-tools/graph-rust",
        "@opensip-tools/graph-go",
        "@opensip-tools/graph-java"
      ]
    },
    "packages/dashboard": {
      "ignore": ["src/vendor/cytoscape-bundle.js"],
      "ignoreDependencies": ["cytoscape", "cytoscape-dagre"]
    },
    "packages/fitness/checks-cpp": {
      "ignoreDependencies": ["@opensip-tools/core"]
    },
    "packages/fitness/engine": {
      "entry": ["src/tool.ts", "src/cli/{fit,dashboard,list-checks,list-recipes}.ts"]
    },
    "packages/simulation/engine": {
      "entry": ["src/tool.ts", "src/cli/sim.ts"]
    }
  }
}
